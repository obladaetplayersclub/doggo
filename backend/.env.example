SERVER_PORT=8080

POSTGRES_DB=doggo
POSTGRES_USER=doggo
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432

DB_URL=jdbc:postgresql://localhost:5432/doggo
DB_USERNAME=doggo
DB_PASSWORD=change-me-postgres-password

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRATION=PT24H
JWT_ISSUER=doggo

STORAGE_TYPE=s3
STORAGE_LOCAL_DIR=./storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=doggo-files
S3_REGION=us-east-1
S3_ACCESS_KEY=change-me-minio-user
S3_SECRET_KEY=change-me-minio-password

MINIO_ROOT_USER=change-me-minio-user
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

REVIEW_DAILY_LIMIT=10
REVIEW_MIN_LENGTH=10
REVIEW_MAX_LENGTH=1000

PUSH_NOTIFICATIONS_ENABLED=false
